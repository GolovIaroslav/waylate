#!/usr/bin/env python3
import argparse
import json
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer


def build_runtime(model_path: str, tokenizer_path: str, device: str):
    try:
        import ctranslate2
        from transformers import AutoTokenizer
    except Exception as exc:
        print(
            "Missing Python dependencies. Install ctranslate2, transformers and sentencepiece.",
            file=sys.stderr,
        )
        print(str(exc), file=sys.stderr)
        raise

    active_device = device
    if active_device == "auto":
        active_device = "cuda" if ctranslate2.get_cuda_device_count() > 0 else "cpu"

    tokenizer = AutoTokenizer.from_pretrained(tokenizer_path)
    translator = ctranslate2.Translator(model_path, device=active_device)
    return translator, tokenizer, active_device


def translate_text(translator, tokenizer, text: str, source: str, target: str) -> str:
    if source != "auto" and hasattr(tokenizer, "src_lang"):
        tokenizer.src_lang = source

    source_ids = tokenizer.encode(text)
    source_tokens = tokenizer.convert_ids_to_tokens(source_ids)
    result = translator.translate_batch(
        [source_tokens],
        target_prefix=[[target]],
        beam_size=4,
        max_decoding_length=512,
    )[0]

    tokens = result.hypotheses[0]
    if tokens and tokens[0] == target:
        tokens = tokens[1:]
    output = tokenizer.decode(tokenizer.convert_tokens_to_ids(tokens), skip_special_tokens=True)
    return output.strip()


def make_handler(translator, tokenizer, active_device):
    class Handler(BaseHTTPRequestHandler):
        def _json(self, status: int, payload):
            encoded = json.dumps(payload).encode("utf-8")
            self.send_response(status)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(encoded)))
            self.end_headers()
            self.wfile.write(encoded)

        def log_message(self, format, *args):
            return

        def do_GET(self):
            if self.path == "/health":
                self._json(200, {"ok": True, "device": active_device})
                return
            self._json(404, {"error": "not found"})

        def do_POST(self):
            if self.path != "/translate":
                self._json(404, {"error": "not found"})
                return
            length = int(self.headers.get("Content-Length", "0"))
            raw = self.rfile.read(length)
            try:
                payload = json.loads(raw.decode("utf-8"))
                text = str(payload.get("text", "")).strip()
                source = str(payload.get("source", "auto"))
                target = str(payload.get("target", "")).strip()
                if not text:
                    self._json(400, {"error": "Nothing to translate"})
                    return
                if not target:
                    self._json(400, {"error": "Missing target language"})
                    return
                translated = translate_text(translator, tokenizer, text, source, target)
            except Exception as exc:
                self._json(500, {"error": str(exc)})
                return
            self._json(200, {"translatedText": translated, "device": active_device})

    return Handler


def main() -> int:
    parser = argparse.ArgumentParser(description="Serve a warm CTranslate2 translation runtime over localhost.")
    parser.add_argument("--model", required=True, help="Converted CTranslate2 model directory")
    parser.add_argument("--tokenizer", required=True, help="Tokenizer directory or Hugging Face tokenizer id")
    parser.add_argument("--device", default="auto", choices=["auto", "cpu", "cuda"])
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, required=True)
    args = parser.parse_args()

    try:
        translator, tokenizer, active_device = build_runtime(args.model, args.tokenizer, args.device)
    except Exception:
        return 2

    server = ThreadingHTTPServer((args.host, args.port), make_handler(translator, tokenizer, active_device))
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        return 0
    finally:
        server.server_close()

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
